# Copy this file to .env and adjust as needed, then run: docker compose up -d

# Absolute path on the HOST to the ./data directory. Required so DockCraft can
# correctly bind-mount /data when it recreates the Minecraft container after a
# settings change. On Linux/macOS this is usually the absolute path to this
# repo's data folder, e.g. /home/you/DockCraft/data
HOST_DATA_PATH=./data

# Secret used to sign login tokens (JWT). If left blank, DockCraft generates a
# random secret on first run and stores it in dockcraft.config.json.
JWT_SECRET=
